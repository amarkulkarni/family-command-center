# Supabase — get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL — use http://localhost:3000 for local dev, your Vercel URL for production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Inbound email webhook — any random string, shared with Cloudflare Email Workers
WEBHOOK_SECRET=your-webhook-secret-here

# Twilio WhatsApp bot
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX
ALLOWED_WHATSAPP_NUMBERS=+1XXXXXXXXXX,+1YYYYYYYYY

# AI — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# Cron — any random string for validating Vercel cron requests
CRON_SECRET=your-cron-secret-here
